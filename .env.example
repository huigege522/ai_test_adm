# 复制本文件为 .env 并填写真实配置，.env 不要提交到 Git

# 被测系统基础 URL
BASE_URL=https://adm.gm825.net

# ── 数据库一：MySQL ──────────────────────────────────────────────
# 部分业务表在本库（与 PolarDB 并存；勿混库执行 baseline 脚本）。
# 对应 conftest.py：db_conn / db_cursor / load_baseline
# 基准 SQL：test_data/sql/shared/baseline.sql、cleanup.sql（示例表 cmp_apple_market）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=test_db
DB_USER=root
DB_PASSWORD=your_password

# apple_app_ext fixture（conftest.adam_id）：固定 adam_id（留空则自动生成；固定值重复跑可能唯一键冲突）
# FIXTURE_APP_EXT_ADAM_ID=

# ── 数据库二：PolarDB（兼容 MySQL 协议，PyMySQL 直接连接）────────
# 部分业务表在本库（与 MySQL 并存）。
# 对应 conftest.py：polar_db_conn / polar_db_cursor；adam_id 在已配置 POLAR_DB_HOST 时也连本库
# 基准 SQL：test_data/sql/basic_info/baseline.sql、cleanup.sql（PolarDB 扩展表）
POLAR_DB_HOST=polar-xxxxx.rwlb.rds.aliyuncs.com
POLAR_DB_PORT=3306
POLAR_DB_NAME=test_db
POLAR_DB_USER=root
POLAR_DB_PASSWORD=your_polardb_password

# ── 认证方式一（推荐）：账密自动登录 ──
# 系统会自动调用 POST /api/login/sub2 登录并获取 Cookie，无需手动复制
LOGIN_USERNAME=
LOGIN_PASSWORD=

# ── 认证方式二（备用）：手动填入 Cookie ──
# 当账密登录因验证码无法绕过时使用
# 从浏览器 F12 → Network → 任意 /api/ 请求 → Request Headers → Cookie 整行复制
AUTH_COOKIE=

# 低权限用户（用于 403 越权测试，不配置则自动跳过该用例）
LOW_PERM_USERNAME=
LOW_PERM_PASSWORD=

# 测试超时（秒）
REQUEST_TIMEOUT=10

# ── API 集成/写库冒烟（按需开启，未设为 1 时对应用例会 skip）────────
# tests/api/test_auto_custom_save.py 成功路径
# INTEGRATION_AUTOCUSTOM_SAVE=1
# INTEGRATION_EXIST_CUSTOM_REPORT_ID=0

# ── Playwright UI E2E（TC110 等 UI 用例必填，详见 prompts/06_e2e_ui_flow.md）──
# 与 BASE_URL（API）区分：须能打开 Vue SPA（含 /managementCenter/productManagement）
# 例：测试环境前端与 API 同域 https://adm.gm825.net（登录页 /login，E2E 填根地址勿带 /login）
PLAYWRIGHT_BASE_URL=https://adm.gm825.net
# E2E_BASIC_INFO_URL=
# TC110 筛选无匹配用的幽灵 org_id（与 API 用例一致）
# TC110_GHOST_ORG_ID=99999999991
