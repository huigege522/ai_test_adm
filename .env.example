# 复制本文件为 .env 并填写真实配置，.env 不要提交到 Git

# 被测系统基础 URL
BASE_URL=https://adm.gm825.net

# MySQL 测试数据库（独立测试库，禁止指向生产库）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=test_db
DB_USER=root
DB_PASSWORD=your_password

# ── 认证方式一（推荐）：账密自动登录 ──
# 系统会自动调用 POST /api/login/sub 登录并获取 Cookie，无需手动复制
LOGIN_USERNAME=
LOGIN_PASSWORD=

# ── 认证方式二（备用）：手动填入 Cookie ──
# 当账密登录因验证码无法绕过时使用
# 从浏览器 F12 → Network → 任意 /api/ 请求 → Request Headers → Cookie 整行复制
AUTH_COOKIE=

# 低权限用户（用于 403 越权测试，不配置则自动跳过该用例）
LOW_PERM_USERNAME=
LOW_PERM_PASSWORD=

# 测试超时（秒）
REQUEST_TIMEOUT=10
